# PostgreSQL for local backend development.
# Docker Compose exposes PostgreSQL on host port 5433 to avoid conflicts with local PostgreSQL on 5432.
DATABASE_URL=postgresql://examrush:examrush@localhost:5433/examrush

# Redis for local backend development.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

SECRET_KEY=change-this-secret-key-in-production-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
